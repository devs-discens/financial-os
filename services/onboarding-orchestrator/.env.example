# ── LLM Configuration ──
ONBOARDING_LLM_PROVIDER=anthropic
ONBOARDING_LLM_MODEL=claude-opus-4-6
ONBOARDING_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ONBOARDING_OPENAI_API_KEY=sk-proj-your-key-here
ONBOARDING_GEMINI_API_KEY=AIzaSy-your-key-here

# ── Logging Configuration ──
ONBOARDING_LOG_LEVEL=DEBUG
ONBOARDING_LOG_FORMAT=%(asctime)s %(name)s [%(levelname)s] %(message)s
ONBOARDING_LOG_FILE=/tmp/onboarding-orchestrator.log
ONBOARDING_LOG_MAX_BYTES=10485760
ONBOARDING_LOG_BACKUP_COUNT=5
